# Copy this file to .env and complete values for your environment.

# Database
ConnectionStrings__LocalConnection=Host=localhost;Port=5432;Database=turnero;Username=turnero;Password=turnero_pwd

# Firebase credentials (path-only pattern)
# 1) Path to service account file
Firebase__CredentialsPath=
# 2) Alternative env variable used by Google SDKs
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: used only by docker-stack.tls.yml for direct Kestrel TLS
LETSENCRYPT_DOMAIN=

# Authentication
Authentication__ValidIssuer=
Authentication__Audience=
Authentication__TokenUri=
Authentication__TokenCode=
Authentication__TokenReset=
